FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    "aiohttp>=3.10.11,<4" \
    nats-py==2.4.0
COPY ark/ ./ark/
COPY emitters/ ./emitters/
COPY internal/contracts/ ./internal/contracts/
COPY policy/ ./policy/
ENV INSTANCE_ID=unifi-0
ENV NATS_URL=nats://nats:4222
ENV UNIFI_URL=https://unifi:8443
ENV UNIFI_USERNAME=
ENV UNIFI_PASSWORD=
ENV UNIFI_SITE=default
ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "emitters.unifi_emitter"]
