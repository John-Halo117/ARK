FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    "aiohttp>=3.10.11,<4" \
    nats-py==2.4.0
COPY ark/ ./ark/
COPY agents/ ./agents/
COPY internal/contracts/ ./internal/contracts/
COPY policy/ ./policy/
ENV INSTANCE_ID=openwolf-base
ENV NATS_URL=nats://nats:4222
ENV PYTHONUNBUFFERED=1
CMD ["python", "-c", "import asyncio\nfrom agents.aider.agent import AiderAgent\nasync def main():\n    agent = AiderAgent('openwolf')\n    await agent.connect()\n    await agent.register()\n    await asyncio.gather(agent.heartbeat_loop(), agent.subscribe_calls())\nasyncio.run(main())"]
