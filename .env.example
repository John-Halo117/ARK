# ============================================================
# ARK Environment Variables
# Copy to .env and fill in required values before starting
# ============================================================

# --- REQUIRED (docker-compose will refuse to start without these) ---

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# Grafana dashboard
GF_ADMIN_PASSWORD=

# Meilisearch
MEILI_MASTER_KEY=

# --- OPTIONAL (defaults to empty / disabled if not set) ---

# Home Assistant long-lived access token
HA_TOKEN=

# Jellyfin API token
JELLYFIN_TOKEN=
JELLYFIN_USER_ID=

# UniFi controller credentials
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default

# UniFi SSL CA bundle path (inside container) — omit to skip SSL verification
# UNIFI_CA_BUNDLE=

# Composio API key
COMPOSIO_API_KEY=

# ARK API authentication (comma-separated tokens; empty = auth disabled)
ARK_API_TOKEN=
# ARK_API_TOKENS=token1,token2

# NetWatch signing seed: 32 bytes as 64 lowercase hex characters.
ARK_SIGNING_SEED_HEX=

# Local content-addressed storage bind mount used by ingestion-leader.
ARK_CAS_ROOT=./data/cas

# Autoscaler authentication
AUTOSCALER_API_KEY=
