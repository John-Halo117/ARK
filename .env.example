# ============================================================================
# ARK OS — All Secrets & Configuration
# ============================================================================
# Copy to .env and fill in values:  cp .env.example .env
# Every secret is in THIS file. Services read it via env_file in docker-compose.
# Lines starting with # are ignored. Leave a value blank to disable that feature.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Grafana admin password (var name must match Grafana's expected env var)
GF_SECURITY_ADMIN_PASSWORD=

# Meilisearch master key
MEILI_MASTER_KEY=

# ── Autoscaler ───────────────────────────────────────────────────────────────
# API key required to call POST /api/spawn (leave blank to block all spawns)
AUTOSCALER_API_KEY=

# ── Home Assistant ───────────────────────────────────────────────────────────
# Long-lived access token (Settings → Security → Long-Lived Access Tokens)
HA_TOKEN=

# ── Composio ─────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=

# ── Jellyfin ─────────────────────────────────────────────────────────────────
JELLYFIN_TOKEN=
JELLYFIN_USER_ID=

# ── UniFi ────────────────────────────────────────────────────────────────────
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default

# Path to a CA certificate *inside the container* for TLS verification.
# If blank, SSL verification is disabled (fine for self-signed certs).
# You must also add a volume mount to the unifi-emitter service, e.g.:
#   volumes:
#     - /host/path/to/ca-cert.pem:/certs/ca.pem:ro
UNIFI_CA_BUNDLE=
