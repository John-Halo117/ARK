# ARK OS - Environment Variables
# Copy this file to .env and fill in the values before running docker-compose up.

# --- Required (docker-compose will refuse to start without these) ---
# Replace with strong, unique values before running docker-compose up.
GF_ADMIN_PASSWORD=
MEILI_MASTER_KEY=

# --- Optional: Autoscaler API key (required to call POST /api/spawn) ---
# AUTOSCALER_API_KEY=some-random-secret

# --- Emitter tokens (leave blank to disable the integration) ---
# HA_TOKEN=your-home-assistant-long-lived-access-token
# COMPOSIO_API_KEY=your-composio-api-key
# JELLYFIN_TOKEN=your-jellyfin-api-key
# JELLYFIN_USER_ID=your-jellyfin-user-id
# UNIFI_USERNAME=your-unifi-username
# UNIFI_PASSWORD=your-unifi-password
# UNIFI_SITE=default
# UNIFI_CA_BUNDLE=/certs/ca.pem
# NOTE: If using UNIFI_CA_BUNDLE, you must also add a volume mount to the
# unifi-emitter service in docker-compose.yml to make the cert available
# inside the container, e.g.:
#   volumes:
#     - /host/path/to/ca-cert.pem:/certs/ca.pem:ro
