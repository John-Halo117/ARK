FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    "aiohttp>=3.10.11,<4" \
    nats-py==2.4.0
COPY ark/ ./ark/
COPY emitters/ ./emitters/
COPY internal/contracts/ ./internal/contracts/
COPY policy/ ./policy/
ENV INSTANCE_ID=jellyfin-0
ENV NATS_URL=nats://nats:4222
ENV JELLYFIN_URL=http://jellyfin:8096
ENV JELLYFIN_TOKEN=
ENV JELLYFIN_USER_ID=
ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "emitters.jellyfin_emitter"]
