FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags='-s -w' -o /out/stability-kernel ./cmd/stability-kernel

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/stability-kernel /usr/local/bin/stability-kernel
EXPOSE 8081
ENTRYPOINT ["/usr/local/bin/stability-kernel"]
