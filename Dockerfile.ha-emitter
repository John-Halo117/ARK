FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    "aiohttp>=3.10.11,<4" \
    nats-py==2.4.0
COPY ark/ ./ark/
COPY emitters/ ./emitters/
COPY internal/contracts/ ./internal/contracts/
COPY policy/ ./policy/
ENV INSTANCE_ID=homeassistant-0
ENV NATS_URL=nats://nats:4222
ENV HA_URL=http://homeassistant:8123
ENV HA_TOKEN=
ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "emitters.homeassistant_emitter"]
