#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
LAST_COMMIT="$(git rev-parse HEAD)"
INGEST_URL="${ARK_INGEST_URL:-http://127.0.0.1:8080/v1/ingest/git-commit}"

payload="$(printf '{"repo_path":"%s","commit_sha":"%s"}' "$REPO_ROOT" "$LAST_COMMIT")"

if command -v curl >/dev/null 2>&1; then
  curl --fail --silent --show-error \
    -H 'Content-Type: application/json' \
    -X POST \
    -d "$payload" \
    "$INGEST_URL" >/dev/null
  printf '[ARK-Field] ingested commit %s via %s\n' "$LAST_COMMIT" "$INGEST_URL"
else
  printf '[ARK-Field] curl missing; commit %s queued for manual ingest\n' "$LAST_COMMIT"
fi
